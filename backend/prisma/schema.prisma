generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  REPORTING_OFFICER
  REVIEWING_OFFICER
  ACCEPTING_OFFICER
  HR
  MANAGING_DIRECTOR
}

enum AppraisalStatus {
  DRAFT
  SUBMITTED
  REPORTING_DONE
  REVIEWING_DONE
  ACCEPTING_DONE
  FINALIZED
}

enum CyclePhase {
  GOAL_SETTING
  MID_YEAR_REVIEW
  ANNUAL_APPRAISAL
}

enum CycleStatus {
  ACTIVE
  CLOSED
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  password           String
  role               Role
  department         String?
  employeeCode       String?  @unique
  reportingOfficerId String?
  reviewingOfficerId String?
  acceptingOfficerId String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  reportingOfficer   User?    @relation("ReportingRelation", fields: [reportingOfficerId], references: [id])
  reportees          User[]   @relation("ReportingRelation")

  kpaGoals           KpaGoal[]
  midYearReviews     MidYearReview[]
  annualAppraisals   AnnualAppraisal[]
  auditLogs          AuditLog[]
  reportingHistory   ReportingHistory[] @relation("UserHistory")

  @@index([role])
  @@index([department])
}

model ReportingHistory {
  id                 String    @id @default(uuid())
  userId             String
  reportingOfficerId String?
  reviewingOfficerId String?
  acceptingOfficerId String?
  startDate          DateTime  @default(now())
  endDate            DateTime?
  
  user               User      @relation("UserHistory", fields: [userId], references: [id])
  
  @@index([userId])
}

model AppraisalCycle {
  id          String      @id @default(uuid())
  name        String      @unique
  year        Int
  phase       CyclePhase
  status      CycleStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime
  description String?
  kpaWeight          Float @default(60)
  valuesWeight       Float @default(20)
  competenciesWeight Float @default(20)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  kpaGoals         KpaGoal[]
  midYearReviews   MidYearReview[]
  annualAppraisals AnnualAppraisal[]

  @@index([year])
  @@index([status])
}

model KpaGoal {
  id          String          @id @default(uuid())
  userId      String
  cycleId     String
  title       String
  description String?
  weightage   Float
  status           AppraisalStatus @default(DRAFT)
  reportingRemarks String?
  submittedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user       User           @relation(fields: [userId], references: [id])
  cycle      AppraisalCycle @relation(fields: [cycleId], references: [id])
  kpaRatings KpaRating[]

  @@index([userId, cycleId])
}

model MidYearReview {
  id               String          @id @default(uuid())
  userId           String
  cycleId          String
  progress         String?
  selfRating       Float?
  reportingRemarks String?
  managerRating    Float?
  status           AppraisalStatus @default(DRAFT)
  submittedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user  User           @relation(fields: [userId], references: [id])
  cycle AppraisalCycle @relation(fields: [cycleId], references: [id])

  @@unique([userId, cycleId])
  @@index([userId, cycleId])
}

model AnnualAppraisal {
  id                String          @id @default(uuid())
  userId            String
  cycleId           String
  achievements      String?
  status            AppraisalStatus @default(DRAFT)

  kpaScore          Float?
  valuesScore       Float?
  competenciesScore Float?
  finalScore        Float?
  ratingBand        String?

  reportingRemarks  String?
  reviewingRemarks  String?
  acceptingRemarks  String?

  submittedAt       DateTime?
  reportingDoneAt   DateTime?
  reviewingDoneAt   DateTime?
  acceptingDoneAt   DateTime?
  finalizedAt       DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  cycle            AppraisalCycle    @relation(fields: [cycleId], references: [id])
  kpaRatings       KpaRating[]
  attributeRatings AttributeRating[]

  @@unique([userId, cycleId])
  @@index([userId, cycleId])
  @@index([status])
}

model KpaRating {
  id                String   @id @default(uuid())
  annualAppraisalId String
  kpaGoalId         String
  rating            Float
  remarks           String?
  ratedBy           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  annualAppraisal AnnualAppraisal @relation(fields: [annualAppraisalId], references: [id])
  kpaGoal         KpaGoal         @relation(fields: [kpaGoalId], references: [id])

  @@unique([annualAppraisalId, kpaGoalId, ratedBy])
}

model AttributeMaster {
  id          String   @id @default(uuid())
  name        String
  type        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  attributeRatings AttributeRating[]

  @@index([type])
}

model AttributeRating {
  id                String   @id @default(uuid())
  annualAppraisalId String
  attributeId       String
  rating            Float
  remarks           String?
  ratedBy           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  annualAppraisal AnnualAppraisal @relation(fields: [annualAppraisalId], references: [id])
  attribute       AttributeMaster @relation(fields: [attributeId], references: [id])

  @@unique([annualAppraisalId, attributeId, ratedBy])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
